name: CI/CD

on:
  push:
    branches: [ main, master ]
  pull_request:
    branches: [ main, master ]
  release:
    types: [created]

jobs:
  test:
    runs-on: ${{ matrix.os }}
    strategy:
      fail-fast: false
      matrix:
        os: [windows-latest, ubuntu-latest, macos-latest]
        python-version: ['3.8', '3.9', '3.10', '3.11', '3.12']

    steps:
    - uses: actions/checkout@v4
    
    - name: Set up Python ${{ matrix.python-version }}
      uses: actions/setup-python@v5
      with:
        python-version: ${{ matrix.python-version }}
    
    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install -r requirements.txt
    
    - name: Test import
      run: |
        python -c "import dxf2kml; print('dxf2kml import OK')"
        python -c "import dxf2kml_gui; print('dxf2kml_gui import OK')"
    
    - name: Test CLI help
      run: |
        python dxf2kml.py --help

  build:
    needs: test
    runs-on: windows-latest
    if: github.event_name == 'release'
    
    steps:
    - uses: actions/checkout@v4
    
    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.11'
    
    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install -r requirements.txt
        pip install pyinstaller
    
    - name: Build executable
      run: |
        pyinstaller --onefile --windowed --name "DXF2KML" --icon=docs/icon.ico dxf2kml_gui.py
        pyinstaller --onefile --name "dxf2kml" dxf2kml.py
    
    - name: Upload Windows executable
      uses: actions/upload-artifact@v4
      with:
        name: DXF2KML-Windows
        path: dist/

  publish-pypi:
    needs: test
    runs-on: ubuntu-latest
    if: github.event_name == 'release'
    
    steps:
    - uses: actions/checkout@v4
    
    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.11'
    
    - name: Install build tools
      run: |
        python -m pip install --upgrade pip
        pip install build twine
    
    - name: Create setup.py
      run: |
        cat > setup.py << 'EOF'
        from setuptools import setup, find_packages
        
        with open("README.md", "r", encoding="utf-8") as fh:
            long_description = fh.read()
        
        setup(
            name="dxf2kml",
            version="${{ github.ref_name }}",
            author="Wang Ningping",
            author_email="174367449@qq.com",
            description="Convert DXF files to KML format with CGCS2000 support",
            long_description=long_description,
            long_description_content_type="text/markdown",
            url="https://github.com/${{ github.repository }}",
            packages=find_packages(),
            classifiers=[
                "Development Status :: 4 - Beta",
                "Intended Audience :: Developers",
                "Topic :: Scientific/Engineering :: GIS",
                "License :: OSI Approved :: MIT License",
                "Programming Language :: Python :: 3",
                "Programming Language :: Python :: 3.8",
                "Programming Language :: Python :: 3.9",
                "Programming Language :: Python :: 3.10",
                "Programming Language :: Python :: 3.11",
                "Programming Language :: Python :: 3.12",
            ],
            python_requires=">=3.8",
            install_requires=[
                "ezdxf>=1.0.0",
                "simplekml>=1.3.6",
                "pyproj>=3.0.0",
            ],
            entry_points={
                "console_scripts": [
                    "dxf2kml=dxf2kml:main",
                ],
            },
        )
        EOF
    
    - name: Build package
      run: python -m build
    
    - name: Publish to PyPI
      env:
        TWINE_wangningpingNAME: __token__
        TWINE_PASSWORD: ${{ secrets.PYPI_API_TOKEN }}
      run: |
        python -m twine upload dist/*
